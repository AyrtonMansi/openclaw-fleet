# OpenClaw Fleet Environment Configuration
# Copy this file to .env and fill in your values

# Domain configuration
DOMAIN=fleet.yourdomain.com

# Database
POSTGRES_PASSWORD=change-me-to-secure-password

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-to-secure-password

# JWT Secret (generate with: openssl rand -base64 48)
SECRET_KEY=change-me-to-secure-secret-key

# Admin user (for initial setup)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me-to-secure-password
